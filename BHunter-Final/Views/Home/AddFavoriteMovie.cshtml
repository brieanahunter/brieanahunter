@model BHunter_Final.Models.AddFavoriteMovie

@{
    Layout = null;
    ViewData["Title"] = "Add Favorite Movie";
    var sidebarUser = ViewBag.SidebarUser as BHunter_Final.Models.SidebarUserViewModel;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <title>Add Favorite Movie</title>
    <link rel="stylesheet" href="~/css/homepage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/favorites.css" asp-append-version="true" />
</head>
<body>
    <partial name="_Sidebar" model="sidebarUser" />

    <main class="favorites-page">
        <div class="favorites-form-card">
            <h1>Add Favorite Movie</h1>

            <form asp-action="AddFavoriteMovie" method="post">
                <div class="form-group">
                    <label for="movieSearch">Search for a movie</label>
                    <input type="text"
                           id="movieSearch"
                           class="form-control"
                           placeholder="Type a movie title..." />
                </div>

                <div class="form-group">
                    <label asp-for="MovieId">Choose a movie</label>
                    <select asp-for="MovieId" class="form-control" id="movieSelect">
                        <option value="">-- Select a movie --</option>
                        @foreach (var movie in Model.AvailableMovies)
                        {
                            <option value="@movie.MovieId">@movie.Title</option>
                        }
                    </select>
                    <span asp-validation-for="MovieId" class="text-danger"></span>
                </div>
                <div class="form-buttons">
                    <button type="submit" class="save-btn">Add Favorite</button>
                    <a asp-action="User" class="cancel-btn">Back</a>
                </div>
            </form>
        </div>
    </main>

    <script>
            const movieSearch = document.getElementById("movieSearch");
            const movieSelect = document.getElementById("movieSelect");

            movieSearch.addEventListener("input", function () {
                const searchText = this.value.toLowerCase();

                for (let i = 0; i < movieSelect.options.length; i++) {
                    const option = movieSelect.options[i];
                    const movieTitle = option.text.toLowerCase();

                    if (option.value === "") {
                        option.hidden = false;
                    } else {
                        option.hidden = !movieTitle.includes(searchText);
                    }
                }
            });
    </script>
</body>
</html>