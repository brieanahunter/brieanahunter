@model BHunter_Final.Models.EditAccount

@{
    Layout = null;
    ViewData["Title"] = "Edit Account";
    var sidebarUser = ViewBag.SidebarUser as BHunter_Final.Models.SidebarUserViewModel;
}

<!DOCTYPE html>
<html>
<head>
    <title>Edit Account</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/homepage.css" asp-append-version="true" />
</head>
<body>
    <partial name="_Sidebar" model="sidebarUser" />

    <div class="page-wrapper">
        <div class="content-wrapper">
            <div class="main-area">
                <div class="w3-card w3-white edit-card">
                    <h2 class="login-title">Edit Account</h2>
                    <hr />

                    <form asp-action="EditAccount" asp-controller="Home" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" class="w3-text-red"></div>

                        <div class="form-group">
                            <label>First Name</label>
                            <input asp-for="FirstName" placeholder="First Name" class="login-input" />
                        </div>

                        <div class="form-group">
                            <label>Last Name</label>
                            <input asp-for="LastName" placeholder="Last Name" class="login-input" />
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input asp-for="Email" placeholder="Email" class="login-input" />
                        </div>

                        <label>Current Profile Picture</label>
                        <div class="w3-margin-bottom">
                            @if (!string.IsNullOrEmpty(Model.CurrentProfileImagePath))
                            {
                                <img src="@Url.Content(Model.CurrentProfileImagePath)" alt="Profile Picture" class="profile-priview-area" />
                            }
                            else
                            {
                                <p>No profile picture uploaded.</p>
                            }
                        </div>

                        <div class="form-group">
                            <label>Upload New Profile Picture</label>
                            <input asp-for="ProfileImage" type="file" class="login-input" accept="image/*" />
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            <input asp-for="NewPassword" type="password" class="login-input" />
                        </div>

                        <div class="form-group">
                            <label>Confirm New Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="login-input" />
                        </div>

                        <button type="submit" class="login-btn">Save Changes</button>
                        <a asp-action="User" asp-controller="Home" class="cancel-btn">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>